[package]
name = "search-service"
version = "0.1.0"
edition = "2021"

[dependencies]
actix-web = "4"
serde = { version = "1", features = ["derive"] }
serde_json = "1"
actix-rt = "2"
reqwest = { version = "0.11", features = ["json"] }
dotenv = "0.15"
futures = "0.3"
elasticsearch = "8.5.0-alpha.1"
log = "0.4"
env_logger = "0.10"
redis = { version = "0.24", features = ["tokio-comp"] }
tokio = { version = "1", features = ["full"] }
